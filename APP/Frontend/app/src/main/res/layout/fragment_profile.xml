<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_profile_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="48dp">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_3d_profile"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="@color/accent_gold"
                        app:strokeWidth="3dp" />

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fabCamera"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:src="@drawable/ic_3d_camera"
                        app:fabCustomSize="32dp"
                        app:backgroundTint="@color/white"
                        app:tint="@color/primary_deep_navy"
                        android:contentDescription="Update Photo" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvName"
                    style="@style/HeadingBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="John Doe"
                    android:textColor="@color/white"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvLevel"
                    style="@style/BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Citizen • Level 5"
                    android:textColor="@color/white"
                    android:alpha="0.8" />

            </LinearLayout>
        </FrameLayout>

        <!-- Stats Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="-30dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatComplaints" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="@color/primary_teal" android:textStyle="bold" android:textSize="18sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Complaints" android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/grey_300" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatResolved" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8" android:textColor="@color/primary_teal" android:textStyle="bold" android:textSize="18sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Resolved" android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/grey_300" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tvStatPoints" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="450" android:textColor="@color/primary_teal" android:textStyle="bold" android:textSize="18sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Points" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Menu Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <include layout="@layout/item_profile_menu" android:id="@+id/menuEdit" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuNotifications" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuLanguage" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuRate" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuPrivacy" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuWhatsNew" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuReport" />
            <include layout="@layout/item_profile_menu" android:id="@+id/menuLogout" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="100dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
