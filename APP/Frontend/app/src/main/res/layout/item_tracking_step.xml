<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <View
        android:id="@+id/lineConnector"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/grey_300"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/dotCircle"
        app:layout_constraintStart_toStartOf="@+id/dotCircle"
        app:layout_constraintTop_toBottomOf="@+id/dotCircle" />

    <FrameLayout
        android:id="@+id/dotCircle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_circle_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivCheck"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_3d_resolved"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/dotCircle"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvStepName"
            style="@style/HeadingBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stage Name"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvTimestamp"
            style="@style/BodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="12 Jun, 10:30 AM"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvStatusMessage"
            style="@style/BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Status message goes here." />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
