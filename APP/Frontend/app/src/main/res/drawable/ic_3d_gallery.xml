<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Elevation Shadow -->
    <path
        android:pathData="M22,70h36v6h-36z"
        android:fillColor="#1A000000" />

    <!-- Back Photo -->
    <path
        android:pathData="M25,20h40v40h-40z"
        android:fillColor="#00796B" />

    <!-- Front Photo -->
    <path
        android:pathData="M15,30h40v40h-40z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="15"
                android:startY="30"
                android:endX="55"
                android:endY="70"
                android:type="linear">
                <item android:color="#00BFA5" android:offset="0.0" />
                <item android:color="#004D40" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Mountain Landscape on Front Photo -->
    <path
        android:pathData="M20,65l10,-20l10,10l10,-15l5,25z"
        android:fillColor="#E0F7FA" />

    <!-- Gold Corner -->
    <path
        android:pathData="M45,30h10v10z"
        android:fillColor="#FFD54F" />

</vector>
