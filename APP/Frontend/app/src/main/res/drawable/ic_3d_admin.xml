<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Elevation Shadow -->
    <path
        android:pathData="M25,65 Q40,75 55,65"
        android:strokeWidth="8"
        android:strokeColor="#1A000000"
        android:strokeLineCap="round" />

    <!-- Shield Body -->
    <path
        android:pathData="M40,15 L60,20 V45 Q60,65 40,75 Q20,65 20,45 V20 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="40"
                android:startY="15"
                android:endX="40"
                android:endY="75"
                android:type="linear">
                <item android:color="#FFF176" android:offset="0.0" />
                <item android:color="#FFD54F" android:offset="0.5" />
                <item android:color="#F9A825" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Navy Eye Symbol on Shield -->
    <path
        android:pathData="M30,40 Q40,25 50,40 Q40,55 30,40 Z"
        android:fillColor="#0A1628" />
    <path
        android:pathData="M40,40m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0"
        android:fillColor="#00BFA5" />

    <!-- Highlight -->
    <path
        android:pathData="M25,25 L35,22 L32,50 L25,45 Z"
        android:fillColor="#33FFFFFF" />

</vector>
