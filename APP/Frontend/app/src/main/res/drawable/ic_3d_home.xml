<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Elevation Shadow -->
    <path
        android:pathData="M20,68h40v6h-40z"
        android:fillColor="#1A000000" />

    <!-- House Body -->
    <path
        android:pathData="M25,40v25h30v-25z"
        android:fillColor="#0A1628" />

    <!-- Roof -->
    <path
        android:pathData="M20,40l20,-20l20,20z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="40"
                android:startY="20"
                android:endX="40"
                android:endY="40"
                android:type="linear">
                <item android:color="#00BFA5" android:offset="0.0" />
                <item android:color="#004D40" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Door -->
    <path
        android:pathData="M37,55v10h6v-10z"
        android:fillColor="#00BFA5" />

</vector>
