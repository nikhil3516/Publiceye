<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Elevation Shadow -->
    <path
        android:pathData="M22,70h36v6h-36z"
        android:fillColor="#1A000000" />

    <!-- Clipboard Board -->
    <path
        android:pathData="M20,15h40a4,4 0,0 1,4 4v50a4,4 0,0 1,-4 4h-40a4,4 0,0 1,-4 -4v-50a4,4 0,0 1,4 -4z"
        android:fillColor="#0A1628" />

    <!-- Paper -->
    <path
        android:pathData="M25,25h30v40h-30z"
        android:fillColor="#F8FFFE" />

    <!-- Clipboard Clip -->
    <path
        android:pathData="M33,10h14v10h-14z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="40"
                android:startY="10"
                android:endX="40"
                android:endY="20"
                android:type="linear">
                <item android:color="#00BFA5" android:offset="0.0" />
                <item android:color="#004D40" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Teal Checkmark -->
    <path
        android:pathData="M35,50l5,5l10,-10"
        android:strokeWidth="4"
        android:strokeColor="#00BFA5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

