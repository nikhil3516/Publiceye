<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Glow Effect -->
    <path
        android:pathData="M40,40m-30,0a30,30 0,1 1,60 0a30,30 0,1 1,-60 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="40"
                android:gradientRadius="30"
                android:type="radial">
                <item android:color="#4DFFD54F" android:offset="0.0" />
                <item android:color="#00FFD54F" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Large Center Star -->
    <path
        android:pathData="M40,20l6,14h14l-11,9 4,14-13-10-13,10 4-14-11-9h14z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="40"
                android:startY="20"
                android:endX="40"
                android:endY="67"
                android:type="linear">
                <item android:color="#FFF176" android:offset="0.0" />
                <item android:color="#FFD54F" android:offset="0.5" />
                <item android:color="#F9A825" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Small Side Star 1 -->
    <path
        android:pathData="M18,35l3,7h7l-6,5 2,7-6-5-6,5 2-7-6-5h7z"
        android:fillColor="#FFD54F" />

    <!-- Small Side Star 2 -->
    <path
        android:pathData="M62,35l3,7h7l-6,5 2,7-6-5-6,5 2-7-6-5h7z"
        android:fillColor="#FFD54F" />

</vector>
