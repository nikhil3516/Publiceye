<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Teal Glow -->
    <path
        android:pathData="M40,40m-35,0a35,35 0,1 1,70 0a35,35 0,1 1,-70 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="40"
                android:gradientRadius="35"
                android:type="radial">
                <item android:color="#4D00BFA5" android:offset="0.0" />
                <item android:color="#0000BFA5" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Brain Base -->
    <path
        android:pathData="M25,45 Q20,45 20,35 Q20,20 40,20 Q60,20 60,35 Q60,45 55,45 Q60,45 60,55 Q60,65 40,65 Q20,65 20,55 Q20,45 25,45 Z"
        android:fillColor="#0A1628" />

    <!-- Circuit Lines -->
    <path
        android:pathData="M35,30h10v10h-10z M35,45h10v10h-10z M25,37h5 M50,37h5"
        android:strokeWidth="1.5"
        android:strokeColor="#00BFA5" />

    <!-- Glowing Nodes -->
    <path
        android:pathData="M40,35m-2,0a2,2 0,1 1,4 0a2,2 0,1 1,-2 -2"
        android:fillColor="#00BFA5" />

</vector>
