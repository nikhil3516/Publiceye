<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Elevation Shadow -->
    <path
        android:pathData="M30,68 Q40,75 50,68"
        android:strokeWidth="4"
        android:strokeColor="#1A000000"
        android:strokeLineCap="round" />

    <!-- Bell Body -->
    <path
        android:pathData="M40,15 Q30,15 25,30 Q20,50 20,60 H60 Q60,50 55,30 Q50,15 40,15 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="40"
                android:startY="15"
                android:endX="40"
                android:endY="60"
                android:type="linear">
                <item android:color="#00E5FF" android:offset="0.0" />
                <item android:color="#00BFA5" android:offset="0.5" />
                <item android:color="#006064" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bell Clapper -->
    <path
        android:pathData="M35,60 Q40,75 45,60 Z"
        android:fillColor="#004D40" />

    <!-- Gold Badge Dot -->
    <path
        android:pathData="M52,22a6,6 0,1 1,12 0a6,6 0,1 1,-12 0"
        android:fillColor="#FFD54F" />

    <!-- Highlight -->
    <path
        android:pathData="M30,25 Q40,18 50,25"
        android:strokeWidth="1.5"
        android:strokeColor="#4DFFFFFF"
        android:strokeLineCap="round" />

</vector>
