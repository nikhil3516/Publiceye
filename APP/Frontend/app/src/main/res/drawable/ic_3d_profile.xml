<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Gold Outer Ring -->
    <path
        android:pathData="M40,40m-35,0a35,35 0,1 1,70 0a35,35 0,1 1,-70 0"
        android:fillColor="#FFD54F" />

    <!-- Teal Circle -->
    <path
        android:pathData="M40,40m-30,0a30,30 0,1 1,60 0a30,30 0,1 1,-60 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="40"
                android:gradientRadius="30"
                android:type="radial">
                <item android:color="#00BFA5" android:offset="0.0" />
                <item android:color="#004D40" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Head -->
    <path
        android:pathData="M40,35m-10,0a10,10 0,1 1,20 0a10,10 0,1 1,-20 0"
        android:fillColor="#FFFFFF" />

    <!-- Shoulders -->
    <path
        android:pathData="M25,60 Q40,45 55,60"
        android:strokeWidth="8"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

</vector>
